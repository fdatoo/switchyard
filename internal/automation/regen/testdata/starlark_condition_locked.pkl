amends "switchyard:automation"
import "switchyard:automations" as auto

// Auto-generated by switchyardd regen — do not edit manually.

id = "smart-lights"
enabled = true
triggers {
  new auto.TimeTrigger {
    at = "20:00"
  }
}
conditions {
  // locked-region:starlark
  new auto.StarlarkCondition {
    expr = #"""
state("sensor.lux").value < 50
  """#
  }
  // end-locked-region
}
actions {
  new auto.CallServiceAction {
    entity = "light.garden"
    capability = "turn_on"
  }
}
