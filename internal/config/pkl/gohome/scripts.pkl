module gohome.scripts

import "gohome:starlark" as starlark

class ScriptParam {
  name:     String(!isEmpty)
  type:     String(this == "string" || this == "int" || this == "float" || this == "bool" || this == "entity_id")
  required: Boolean = true
  default:  String?
}

class Script {
  name:    String(!isEmpty)
  params:  Listing<ScriptParam> = new {}
  handler: starlark.StarlarkScript
}
