module switchyard.dashboards

import "switchyard:widgets" as widgets

class LeafWidget extends widgets.WidgetInstance {
  widgetClass: String
  props: Mapping<String, Any> = new {}
}

class ContainerWidget extends widgets.WidgetInstance {
  childGrid: widgets.Grid = new {}
  children: Listing<widgets.WidgetInstance> = new {}
}

class Dashboard {
  slug: String(!isEmpty)
  title: String = ""
  grid: widgets.Grid = new {}
  widgets: Listing<widgets.WidgetInstance> = new {}
}

class LayoutFile {
  grid: widgets.Grid = new {}
  widgets: Listing<widgets.WidgetInstance> = new {}
}
